menu "LoongArch-core configuration menu"

menu "TRACE_WAVE switch"
  config TRACE_WAVE
    bool "Enable trace wave"
    default n
  config WAVE_PC_START
    hex "wave pc start"
    default 0x30000000
  config WAVE_PC_END
    hex "wave pc end"
    default 0x30000000
endmenu

endmenu

menu "LoongArch-core difftest config"
  config DIFFTEST
    bool "Enable difftest"
    default n
endmenu

menu "LoongArch-core performance trace config"
  config TRACE_PERFORMANCE
    bool "Enable performance tracer"
    default y
endmenu

menu "TLB Config"
config TLB_ENTRIES
    hex "Number of TLB entries (power of 2)"
    default 0x8
endmenu

